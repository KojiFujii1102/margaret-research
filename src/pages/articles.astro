---
import Layout from '../layouts/Layout.astro';
---

<Layout title="記事一覧" description="マーガレット リサーチの記事一覧 - AI関連の記事紹介と実験レポート">

  <div class="mb-12">
    <h1 class="text-3xl font-bold text-ai tracking-widest mb-3">
      <span class="text-kin mr-2">◆</span>記事一覧
    </h1>
    <p class="text-sm text-gray-500 font-sans">AIの世界の探索レポート</p>
  </div>

  <!-- カテゴリフィルター -->
  <div class="flex gap-3 mb-10 flex-wrap font-sans">
    <button class="px-4 py-1.5 text-sm bg-ai text-white rounded-full">すべて</button>
    <button class="px-4 py-1.5 text-sm border border-gray-300 text-gray-600 rounded-full hover:border-ai hover:text-ai transition-colors">記事紹介</button>
    <button class="px-4 py-1.5 text-sm border border-gray-300 text-gray-600 rounded-full hover:border-ai hover:text-ai transition-colors">使ってみた</button>
    <button class="px-4 py-1.5 text-sm border border-gray-300 text-gray-600 rounded-full hover:border-ai hover:text-ai transition-colors">実験レポート</button>
    <button class="px-4 py-1.5 text-sm border border-gray-300 text-gray-600 rounded-full hover:border-ai hover:text-ai transition-colors">アイデア</button>
  </div>

  <!-- 記事リスト -->
  <div class="space-y-6">
    <article class="bg-white rounded-lg p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
      <div class="flex items-start gap-4">
        <div class="text-3xl">🤖</div>
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-xs bg-ai/10 text-ai px-2 py-1 rounded font-sans">準備中</span>
            <time class="text-xs text-gray-400 font-sans">2026-04-09</time>
          </div>
          <h2 class="text-lg font-bold text-sumi mb-2">
            第1号記事、間もなく公開
          </h2>
          <p class="text-sm text-gray-500 font-sans leading-relaxed">
            最初の記事を鋭意作成中です。もうしばらくお待ちください。
          </p>
        </div>
      </div>
    </article>
  </div>

</Layout>
