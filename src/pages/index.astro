---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ホーム">

  <!-- ヒーローセクション -->
  <section class="relative text-center pt-16 pb-20 mb-16 overflow-hidden">
    <!-- 背景装飾：和風幾何学パターン -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <!-- 大きな円 -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full border border-ai/8"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 rounded-full border border-ai/6"></div>
      <!-- 角の装飾 -->
      <div class="absolute top-4 left-4 w-16 h-16 border-t-2 border-l-2 border-kin/40"></div>
      <div class="absolute top-4 right-4 w-16 h-16 border-t-2 border-r-2 border-kin/40"></div>
      <div class="absolute bottom-4 left-4 w-16 h-16 border-b-2 border-l-2 border-kin/40"></div>
      <div class="absolute bottom-4 right-4 w-16 h-16 border-b-2 border-r-2 border-kin/40"></div>
      <!-- 流水風の横線 -->
      <div class="absolute top-8 left-0 right-0 flex justify-center gap-1 opacity-20">
        <div class="h-px w-24 bg-ai"></div>
        <div class="h-px w-8 bg-ai"></div>
        <div class="h-px w-16 bg-ai"></div>
      </div>
      <div class="absolute bottom-8 left-0 right-0 flex justify-center gap-1 opacity-20">
        <div class="h-px w-16 bg-ai"></div>
        <div class="h-px w-8 bg-ai"></div>
        <div class="h-px w-24 bg-ai"></div>
      </div>
    </div>

    <!-- 家紋風シンボル -->
    <div class="relative z-10 mb-8">
      <div class="inline-flex items-center justify-center w-24 h-24 rounded-full border-2 border-ai bg-white shadow-md">
        <div class="w-20 h-20 rounded-full border border-ai/30 flex items-center justify-center">
          <span class="text-4xl text-ai">菊</span>
        </div>
      </div>
    </div>

    <!-- タイトル -->
    <div class="relative z-10">
      <!-- 上部装飾ライン -->
      <div class="flex items-center justify-center gap-3 mb-5">
        <div class="h-px w-16 bg-gradient-to-r from-transparent to-kin/60"></div>
        <span class="text-kin text-xs tracking-widest font-sans">MARGARET RESEARCH</span>
        <div class="h-px w-16 bg-gradient-to-l from-transparent to-kin/60"></div>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-ai tracking-widest mb-5 leading-tight">
        マーガレット リサーチ
      </h1>

      <!-- 下部装飾ライン -->
      <div class="flex items-center justify-center gap-3 mb-8">
        <div class="h-px w-12 bg-ai/20"></div>
        <span class="text-ai/40 text-xs">◆</span>
        <div class="h-px w-12 bg-ai/20"></div>
      </div>

      <p class="text-lg text-gray-600 font-sans leading-relaxed mb-3">
        AI の世界を、ともに探索する。
      </p>
      <p class="text-sm text-gray-400 font-sans tracking-wider">
        記事紹介 &ensp;／&ensp; 実験レポート &ensp;／&ensp; 使ってみた
      </p>
    </div>
  </section>

  <!-- 最新記事セクション -->
  <section class="mb-16">
    <div class="flex items-center gap-3 mb-8">
      <span class="text-kin text-sm">◆</span>
      <h2 class="text-2xl font-bold text-ai tracking-widest">最新記事</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-ai/30 to-transparent"></div>
    </div>

    <!-- 記事カード -->
    <div class="space-y-5">
      <article class="group relative bg-white rounded-lg overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5">
        <!-- 左ボーダーアクセント -->
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-asagi to-ai rounded-l-lg"></div>
        <div class="pl-7 pr-6 py-5 flex items-start gap-4">
          <!-- アイコンエリア -->
          <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-ai/5 border border-ai/10 flex items-center justify-center text-2xl group-hover:bg-ai/10 transition-colors">
            🤖
          </div>
          <div class="flex-1 min-w-0">
            <!-- メタ情報 -->
            <div class="flex items-center gap-3 mb-2 flex-wrap">
              <span class="inline-flex items-center text-xs bg-asagi/10 text-asagi border border-asagi/20 px-2.5 py-0.5 rounded-full font-sans font-medium">使ってみた</span>
              <time class="text-xs text-gray-400 font-sans">2026-04-09</time>
            </div>
            <!-- タイトル -->
            <h3 class="text-base md:text-lg font-bold text-sumi mb-2 group-hover:text-ai transition-colors leading-snug">
              <a href="#" class="stretched-link">記事準備中 — もうすぐ公開します</a>
            </h3>
            <!-- 概要 -->
            <p class="text-sm text-gray-500 font-sans leading-relaxed line-clamp-2">
              マーガレット リサーチの最初の記事を準備中です。AIツールの実験レポートや注目記事の紹介をお届けします。お楽しみに。
            </p>
          </div>
        </div>
      </article>
    </div>

    <div class="text-center mt-10">
      <a href="/articles" class="inline-flex items-center gap-2 border-2 border-ai text-ai px-8 py-2.5 text-sm font-sans font-medium hover:bg-ai hover:text-white transition-all duration-200 tracking-wider rounded-sm">
        <span>記事一覧を見る</span>
        <span class="text-xs">→</span>
      </a>
    </div>
  </section>

  <!-- コンセプトセクション -->
  <section class="bg-white rounded-xl p-8 border border-gray-100 shadow-sm">
    <div class="flex items-center gap-3 mb-8">
      <span class="text-kin text-sm">◆</span>
      <h2 class="text-xl font-bold text-ai tracking-widest">このサイトについて</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-ai/30 to-transparent"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-6 font-sans">
      <div class="group text-center p-5 rounded-lg border border-transparent hover:border-ai/10 hover:bg-ai/2 transition-all duration-200">
        <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-ai/5 border border-ai/10 flex items-center justify-center text-2xl group-hover:bg-ai/10 transition-colors">
          📰
        </div>
        <h3 class="font-bold text-sumi mb-2 tracking-wide">記事紹介</h3>
        <p class="text-sm text-gray-500 leading-relaxed">AIに関する注目記事や論文を、わかりやすく紹介します。</p>
      </div>
      <div class="group text-center p-5 rounded-lg border border-transparent hover:border-ai/10 hover:bg-ai/2 transition-all duration-200">
        <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-ai/5 border border-ai/10 flex items-center justify-center text-2xl group-hover:bg-ai/10 transition-colors">
          🔬
        </div>
        <h3 class="font-bold text-sumi mb-2 tracking-wide">実験レポート</h3>
        <p class="text-sm text-gray-500 leading-relaxed">実際にAIツールを使ってみた結果をレポートします。</p>
      </div>
      <div class="group text-center p-5 rounded-lg border border-transparent hover:border-ai/10 hover:bg-ai/2 transition-all duration-200">
        <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-ai/5 border border-ai/10 flex items-center justify-center text-2xl group-hover:bg-ai/10 transition-colors">
          💡
        </div>
        <h3 class="font-bold text-sumi mb-2 tracking-wide">アイデア発信</h3>
        <p class="text-sm text-gray-500 leading-relaxed">AIを活用したアイデアや考察を発信します。</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* 記事カードのストレッチリンク */
  .stretched-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }
</style>
