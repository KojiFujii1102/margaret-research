---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.md$/, '') },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

// 前後の記事を取得
const allArticles = await getCollection('articles');
const sorted = allArticles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const currentIndex = sorted.findIndex((a) => a.id === article.id);
const prevArticle = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextArticle = currentIndex > 0 ? sorted[currentIndex - 1] : null;

// カテゴリの表示名マッピング
const categoryLabel: Record<string, string> = {
  article: '記事紹介',
  tried: '使ってみた',
  experiment: '実験レポート',
  idea: 'アイデア',
};

const categoryColor: Record<string, string> = {
  article: 'bg-ai/10 text-ai',
  tried: 'bg-asagi/10 text-asagi',
  experiment: 'bg-beni/10 text-beni',
  idea: 'bg-kin/10 text-kin',
};

const { title, description, date, category, tags } = article.data;
const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={description}>

  <!-- パンくずリスト -->
  <nav class="text-xs text-gray-400 font-sans mb-8 flex items-center gap-2">
    <a href="/" class="hover:text-ai transition-colors">ホーム</a>
    <span>›</span>
    <a href="/articles" class="hover:text-ai transition-colors">記事一覧</a>
    <span>›</span>
    <span class="text-gray-600 truncate max-w-xs">{title}</span>
  </nav>

  <article class="max-w-2xl mx-auto">

    <!-- ヘッダー -->
    <header class="mb-10 pb-8 border-b border-gray-200">
      <div class="flex items-center gap-3 mb-4">
        <span class={`text-xs px-2.5 py-1 rounded font-sans ${categoryColor[category]}`}>
          {categoryLabel[category]}
        </span>
        <time class="text-xs text-gray-400 font-sans" datetime={date.toISOString()}>
          {formattedDate}
        </time>
      </div>

      <h1 class="text-2xl font-bold text-sumi leading-relaxed mb-4 tracking-wide">
        {title}
      </h1>

      <p class="text-sm text-gray-500 font-sans leading-relaxed">
        {description}
      </p>

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs text-gray-400 font-sans border border-gray-200 px-2 py-0.5 rounded-sm">
              # {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- 本文 -->
    <div class="article-body">
      <Content />
    </div>

    <!-- 区切り -->
    <div class="flex items-center gap-4 my-12">
      <div class="flex-1 h-px bg-gray-200"></div>
      <span class="text-kin text-lg">菊</span>
      <div class="flex-1 h-px bg-gray-200"></div>
    </div>

    <!-- 前後の記事ナビゲーション -->
    <nav class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {prevArticle ? (
        <a
          href={`/articles/${prevArticle.id.replace(/\.md$/, '')}`}
          class="group bg-white border border-gray-100 rounded-lg p-4 hover:shadow-md hover:border-ai/30 transition-all"
        >
          <div class="text-xs text-gray-400 font-sans mb-1 flex items-center gap-1">
            <span>←</span>
            <span>前の記事</span>
          </div>
          <div class="text-sm font-bold text-sumi group-hover:text-ai transition-colors leading-snug">
            {prevArticle.data.title}
          </div>
        </a>
      ) : (
        <div></div>
      )}

      {nextArticle ? (
        <a
          href={`/articles/${nextArticle.id.replace(/\.md$/, '')}`}
          class="group bg-white border border-gray-100 rounded-lg p-4 hover:shadow-md hover:border-ai/30 transition-all text-right"
        >
          <div class="text-xs text-gray-400 font-sans mb-1 flex items-center gap-1 justify-end">
            <span>次の記事</span>
            <span>→</span>
          </div>
          <div class="text-sm font-bold text-sumi group-hover:text-ai transition-colors leading-snug">
            {nextArticle.data.title}
          </div>
        </a>
      ) : (
        <div></div>
      )}
    </nav>

    <!-- 一覧に戻るリンク -->
    <div class="mt-8 text-center">
      <a
        href="/articles"
        class="inline-flex items-center gap-2 text-sm text-ai hover:text-ai/70 font-sans transition-colors"
      >
        <span>←</span>
        <span>記事一覧に戻る</span>
      </a>
    </div>

  </article>

</Layout>

<style is:global>
  /* 記事本文のプロズスタイル */
  .article-body {
    color: #1a1a1a;
    line-height: 2;
    font-size: 1rem;
  }

  .article-body p {
    margin-bottom: 1.75em;
  }

  .article-body h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e3a5f;
    margin-top: 2.5em;
    margin-bottom: 1em;
    padding-left: 0.75em;
    border-left: 3px solid #c9a84c;
    letter-spacing: 0.05em;
  }

  .article-body h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  .article-body ul {
    list-style: none;
    margin-bottom: 1.75em;
    padding-left: 1.5em;
  }

  .article-body ul li {
    position: relative;
    margin-bottom: 0.5em;
  }

  .article-body ul li::before {
    content: '・';
    position: absolute;
    left: -1.25em;
    color: #c9a84c;
  }

  .article-body ol {
    list-style: decimal;
    padding-left: 2em;
    margin-bottom: 1.75em;
  }

  .article-body ol li {
    margin-bottom: 0.5em;
  }

  .article-body a {
    color: #1e3a5f;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-body a:hover {
    color: #4a8fa8;
  }

  .article-body blockquote {
    border-left: 3px solid #e5e7eb;
    padding-left: 1.25em;
    color: #6b7280;
    margin: 1.75em 0;
    font-style: italic;
  }

  .article-body code {
    background: #f3f4f6;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.875em;
    font-family: 'Courier New', monospace;
  }

  .article-body pre {
    background: #1a1a1a;
    color: #f5f0e8;
    padding: 1.25em;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1.75em 0;
    font-size: 0.875em;
  }

  .article-body pre code {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  .article-body hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2.5em 0;
  }
</style>
