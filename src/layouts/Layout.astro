---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'マーガレット リサーチ - AI関連の記事紹介と実験レポート' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | マーガレット リサーチ</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;600;700&family=Noto+Sans+JP:wght@400;500&display=swap" rel="stylesheet" />
    <!-- Google Translate -->
    <script type="text/javascript">
      function googleTranslateElementInit() {
        new google.translate.TranslateElement(
          {
            pageLanguage: 'ja',
            includedLanguages: 'ja,en,zh-CN',
            layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
            autoDisplay: false,
          },
          'google_translate_element'
        );
      }
    </script>
    <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
  </head>
  <body class="bg-washi text-sumi font-serif min-h-screen">

    <!-- ヘッダー -->
    <header class="border-b-2 border-ai bg-white/90 backdrop-blur-sm sticky top-0 z-50 shadow-sm">
      <!-- メインナビゲーション行 -->
      <div class="max-w-4xl mx-auto px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 no-underline group">
          <div class="w-10 h-10 rounded-full border-2 border-ai flex items-center justify-center text-ai text-xl group-hover:bg-ai group-hover:text-white transition-all duration-300">菊</div>
          <div>
            <div class="text-lg font-bold text-ai tracking-widest leading-tight">マーガレット リサーチ</div>
            <div class="text-xs text-gray-400 tracking-wider font-sans">MARGARET RESEARCH</div>
          </div>
        </a>
        <nav class="flex items-center gap-1">
          <a href="/" class="text-sm text-sumi hover:text-ai hover:bg-ai/5 transition-all px-3 py-2 rounded font-sans">ホーム</a>
          <a href="/articles" class="text-sm text-sumi hover:text-ai hover:bg-ai/5 transition-all px-3 py-2 rounded font-sans">記事</a>
          <a href="/about" class="text-sm text-sumi hover:text-ai hover:bg-ai/5 transition-all px-3 py-2 rounded font-sans">About</a>
        </nav>
      </div>
      <!-- 翻訳ウィジェット行 -->
      <div class="border-t border-gray-100 bg-gray-50/80">
        <div class="max-w-4xl mx-auto px-6 py-1 flex items-center justify-end gap-2">
          <span class="text-xs text-gray-400 font-sans">翻訳：</span>
          <div id="google_translate_element" class="text-xs font-sans translate-widget"></div>
        </div>
      </div>
    </header>

    <!-- メインコンテンツ -->
    <main class="max-w-4xl mx-auto px-6 py-10">
      <slot />
    </main>

    <!-- フッター -->
    <footer class="border-t-2 border-ai/20 mt-20 bg-white/50">
      <div class="max-w-4xl mx-auto px-6 py-10">
        <!-- 装飾ライン -->
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="h-px flex-1 bg-gradient-to-r from-transparent to-ai/20"></div>
          <div class="text-ai text-lg">菊</div>
          <div class="h-px flex-1 bg-gradient-to-l from-transparent to-ai/20"></div>
        </div>
        <div class="text-center">
          <p class="text-sm font-bold text-ai tracking-widest font-serif mb-1">マーガレット リサーチ</p>
          <p class="text-xs text-gray-400 font-sans mb-3">AI の世界を、ともに探索する。</p>
          <p class="text-xs text-gray-400 font-sans">© 2026 マーガレット リサーチ</p>
        </div>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  body {
    background-image:
      radial-gradient(circle at 15% 30%, rgba(30, 58, 95, 0.04) 0%, transparent 55%),
      radial-gradient(circle at 85% 10%, rgba(74, 143, 168, 0.04) 0%, transparent 50%),
      radial-gradient(circle at 50% 80%, rgba(201, 168, 76, 0.03) 0%, transparent 45%);
  }

  /* Google翻訳バナーを非表示 */
  .goog-te-banner-frame { display: none !important; }
  body { top: 0 !important; }
  .skiptranslate { display: none !important; }

  /* 翻訳ウィジェットのスタイル調整 */
  .translate-widget .goog-te-gadget {
    font-size: 11px !important;
    color: #6b7280 !important;
  }
  .translate-widget .goog-te-gadget-simple {
    border: 1px solid #e5e7eb !important;
    border-radius: 4px !important;
    padding: 2px 6px !important;
    background: white !important;
    font-size: 11px !important;
  }
  .translate-widget .goog-te-gadget-simple:hover {
    border-color: #1e3a5f !important;
  }

  a { color: inherit; text-decoration: none; }
  a:hover { text-decoration: none; }

  /* スクロールバーのスタイル */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #f5f0e8; }
  ::-webkit-scrollbar-thumb { background: #1e3a5f40; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #1e3a5f80; }
</style>
